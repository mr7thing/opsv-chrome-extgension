{
    "manifest_version": 3,
    "name": "OpenSpec-Video Companion",
    "version": "0.4.0",
    "description": "Browser automation companion for OpenSpec-Video — Gemini/webapp tasks",
    "permissions": [
        "sidePanel",
        "activeTab",
        "scripting",
        "storage",
        "clipboardRead",
        "clipboardWrite"
    ],
    "host_permissions": [
        "https://gemini.google.com/*",
        "ws://127.0.0.1:3061/*",
        "ws://127.0.0.1:3062/*",
        "ws://127.0.0.1:3063/*",
        "ws://127.0.0.1:3064/*",
        "ws://127.0.0.1:3065/*",
        "http://127.0.0.1:9700/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "OpenSpec-Video Companion"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://gemini.google.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}
