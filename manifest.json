{
    "manifest_version": 3,
    "name": "OpenSpec-Video Companion",
    "version": "0.3.2",
    "description": "Browser automation companion for OpenSpec-Video",
    "permissions": [
        "sidePanel",
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://gemini.google.com/*",
        "ws://localhost:3061/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "OpenSpec-Video Companion"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://gemini.google.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}